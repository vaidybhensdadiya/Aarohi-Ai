# ====================================================================
# 🛡️ SECURITY & SENSITIVE SECRETS (Never Commit to Git)
# ====================================================================
# Kubernetes Raw Credentials & Private Keys
*.key
*.pem
*.pub
cosign.key
cosign.pub

# Local Kubernetes Secrets / ConfigMaps
K8s/secrets.yml
K8s/configmap.yml
secrets.yaml
configmap.yaml

# Environment files containing live system access strings
.env
.env.*
*.env

# ====================================================================
# 🏗️ TERRAFORM STATE & COMPILATION ARTIFACTS
# ====================================================================
# Local hidden tracking directories
.terraform/
terraform/.terraform/
*.zip

.terraform.*

# Local tracking state files (Contains raw AWS resource IDs and meta passwords)
*.tfstate
*.tfstate.*

# Crash logs and runtime lock overrides
crash.log
*.tfvars
*.tfvars.json
.terraform.lock.hcl

# ====================================================================
# 🐍 PYTHON RUNTIME & DEPENDENCY BUILD ARTIFACTS
# ====================================================================
# Compiled python byte code caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments wrappers
venv/
.venv/
env/
ENV/
*.venv

# ML model weights caches / local checkpoints
.pytest_cache/
.ipynb_checkpoints/
*.h5
*.pkl
*.onnx

# ====================================================================
# 🍏 SYSTEM & IDE OVERRIDES
# ====================================================================
.DS_Store
.idea/
.vscode/
*.swp
*.log

